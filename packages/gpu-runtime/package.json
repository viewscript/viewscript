{
  "name": "@viewscript/gpu-runtime",
  "version": "0.1.0",
  "description": "Standalone WebGPU runtime for ViewScript compiled output",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "viewscript",
    "webgpu",
    "graphics",
    "rendering"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@webgpu/types": "^0.1.40",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {},
  "engines": {
    "node": ">=18"
  }
}
